{
  "manifest_version": 3,
  "name": "AI YouTube Learning Assistant",
  "version": "1.0",
  "description": "Summarize YouTube videos using AI",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
  {
    "matches": ["https://www.youtube.com/*"],
    "js": ["content.js"]
  }
]
}